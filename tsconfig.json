{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@miko/plugin-protocol": ["packages/plugin-protocol/src/index.ts"],
      "@miko/plugin-sdk": ["packages/plugin-sdk/src/index.ts"],
      "@miko/plugin-runtime": ["packages/plugin-runtime/src/index.ts"],
      "@miko/plugin-components": ["packages/plugin-components/src/index.ts"],
      "@/*": ["desktop/src/react/*"]
    }
  },
  "include": [
    "desktop/src/**/*.ts",
    "desktop/src/**/*.tsx",
    "packages/*/src/**/*.ts",
    "packages/*/src/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "desktop/dist-renderer"
  ]
}
